{
    "enabled": false,
    "provider": "mock",
    "model": "models/gemini-3.5-flash",
    "advisory_only": true,
    "allow_trade_execution": false,
    "allow_threshold_changes": false,
    "allow_configuration_changes": false,
    "max_candidates": 6,
    "max_recommendations": 3,
    "timeout_seconds": 30,
    "retry_count": 2,
    "enable_strategy_proposals": false,
    "enable_reviewed_proposal_experiment": false,
    "max_strategy_proposals": 5,
    "max_indicators_per_strategy": 4,
    "max_parameter_combinations_per_proposal": 16,
    "allowed_indicators": [
        "EMA",
        "RSI",
        "MACD",
        "VOLUME",
        "BOLLINGER",
        "SUPERTREND",
        "CANDLESTICK"
    ],
    "allowed_timeframes": ["15m", "1h"],
    "allowed_market_scope": [
        "BTCUSDT",
        "ETHUSDT",
        "BNBUSDT",
        "SOLUSDT",
        "XRPUSDT"
    ],
    "allow_multi_timeframe_confirmation": false,
    "require_human_review_before_activation": true,
    "proposal_output_path": "reports/ai_strategy_proposals.json",
    "accepted_strategy_output_path": "reports/accepted_ai_strategy_proposals.json",
    "candidate_definition_output_path": "reports/ai_strategy_candidate_definitions.json",
    "proposal_risk_per_trade_fraction": 0.01,
    "proposal_max_capital_allocation_fraction": 0.25,
    "proposal_experiment_report_path": "reports/ai_strategy_proposal_experiment.csv",
    "proposal_experiment_summary_path": "reports/ai_strategy_proposal_experiment_summary.json",
    "output_path": "reports/ai_research_analysis.json",
    "input_report_paths": {
        "benchmark_summary": "reports/final_benchmark_summary.json",
        "benchmark_shortlist": "reports/final_benchmark_shortlist.json",
        "benchmark_stages": "reports/benchmark_stage_summary.csv",
        "phase_21_1": "reports/phase_21_1_candidate_failure_attribution.json",
        "phase_21_2": "reports/phase_21_2_volatility_normalized_exit_report.json",
        "phase_21_3": "reports/phase_21_3_risk_normalized_position_sizing_report.json"
    }
}
